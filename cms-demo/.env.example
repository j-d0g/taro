# Copy to .env (gitignored via root *.env). Required for publish.

# Demo auth — send as: Authorization: Bearer <token>
CMS_ADMIN_TOKEN=replace-me-with-your-token

# Optional — only if your repo layout differs. Otherwise omit both lines (defaults work).
# TARO_CONTENT_POLICY_DIR=/full/path/to/taro-api/content/policy
# TARO_PYTHON=/full/path/to/taro-api/.venv/bin/python

# Taro API (for optional enqueue publish + citation links in UI)
TARO_API_BASE=http://localhost:8002

# Server
CMS_HOST=0.0.0.0
CMS_PORT=8088

# Publish: direct = subprocess ingest-file (default). enqueue = POST /ingest/policy + CLI drain (Layer 2 demo).
PUBLISH_MODE=direct

# Only if PUBLISH_MODE=enqueue — must match taro-api INGEST_WEBHOOK_SECRET; set INGESTION_BACKEND=file in Taro when using drain.
# INGEST_WEBHOOK_SECRET=
