# Copy to taro-api/config/.env and/or repo-root .config/.env (both gitignored).
# Values in .config/.env override config/.env when both exist (see src/env_bootstrap.py).

# SurrealDB (URL port must match `make surrealdb` — default bind 127.0.0.1:8001)
SURREALDB_URL=ws://localhost:8001/rpc
SURREALDB_NAMESPACE=hackathon
SURREALDB_DATABASE=chatbot
SURREALDB_USER=root
SURREALDB_PASS=root

# LLM provider settings (openai | anthropic | google)
LLM_PROVIDER=openai
LLM_MODEL=gpt-5-mini
LLM_TEMPERATURE=0.3

# OpenAI
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic (optional)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google (optional)
GOOGLE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Tavily
TAVILY_API_KEY=tvly-dev-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LangSmith (US API default; set LANGSMITH_TRACING=false if you want tracing off)
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=lsv2_pt_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGSMITH_PROJECT=taro

# LangGraph agent max steps (default 25; increase only as a last resort)
# AGENT_RECURSION_LIMIT=25

# Policy ingestion (Layers 2–3): optional queue + webhook
# INGESTION_BACKEND=none | file | redis
INGESTION_BACKEND=none
REDIS_URL=redis://localhost:6379/0
# Secret for POST /ingest/policy (X-Ingest-Token header)
INGEST_WEBHOOK_SECRET=
