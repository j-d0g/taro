# SurrealDB
SURREALDB_URL=ws://localhost:8001/rpc
SURREALDB_NAMESPACE=hackathon
SURREALDB_DATABASE=chatbot
SURREALDB_USER=root
SURREALDB_PASS=root

# LLM provider settings (openai | anthropic | google)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.3

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic (optional)
ANTHROPIC_API_KEY=sk-ant-...

# Google (optional)
GOOGLE_API_KEY=AIza...

# Tavily
TAVILY_API_KEY=tvly-...

# LangSmith
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGSMITH_API_KEY=lsv2_pt_...
LANGSMITH_PROJECT=taro
